{
  "name": "foundit-monorepo",
  "private": true,
  "scripts": {
    "build": "npm --prefix foundit-frontend install && npm --prefix foundit-frontend run build",
    "frontend:install": "npm --prefix foundit-frontend install",
    "frontend:build": "npm --prefix foundit-frontend run build",
    "frontend:dev": "npm --prefix foundit-frontend run dev"
  }
}
